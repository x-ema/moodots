<layout>
  <theme>
    <var key="clock0_size" value="46"/>
    <var key="clock0_date_size" value="16"/>
    <var key="clock0_dow_size" value="16"/>
    <var key="clock_alt1_color" value="#8bd5ca"/>
    <var key="clock_alt2_color" value="#b7bdf8"/>
    <var key="clock_alt_size" value="24"/>
    <var key="clock_alt_tz_size" value="14"/>
    <var key="color_accent" value="#33ff33"/>
    <var key="button_size" value="40"/>
    <var key="color_accent_translucent" value="#009900"/>
    <var key="color_accent_40" value="#33ff33"/>
		<var key="color_accent_10" value="#00cc00"/>
		<var key="media_icon_color" value="#000000"/>
		<var key="media_icon_size" value="50"/>
		<var key="color_accent_keycaps" value="#00cc00"/>
		<var key="color_accent_keycaps2" value="#999999"/>
  </theme>
	  <macro name="decorative_rect" padding="8" color="~color_bg" border="2" border_color="~color_accent" round="8"/>
  <macro name="button_style" padding="8" border_color="~color_accent_translucent" border="2" round="8" color="~color_accent_40" color2="~color_accent_10" gradient="vertical" align_items="center" justify_content="center"/>
  <macro name="media_button_style" padding="8" border_color="~color_accent_translucent" max_width="50" max_height="50" min_width="50" min_height="50" border="2" round="8" color="~color_accent_40" color2="~color_accent_10" gradient="vertical" align_items="center" justify_content="center"/>

  <template name="SlimeVRButton">
    <Button tooltip="${tooltip}" _press="${event}">
      <sprite width="~button_size" height="~button_size" src="${icon}"/>
    </Button>
  </template>



</layout>
